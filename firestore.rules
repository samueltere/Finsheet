rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('admin') || (request.auth.token.email == "samuelareficho68@gmail.com" && request.auth.token.email_verified == true);
    }

    function isReceptionist() {
      return hasRole('receptionist');
    }

    function isAccountant() {
      return hasRole('accountant');
    }

    function isHousekeeping() {
      return hasRole('housekeeping');
    }

    function isMaintenance() {
      return hasRole('maintenance');
    }

    function isKitchen() {
      return hasRole('kitchen');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isReceptionist());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /rooms/{roomId} {
      allow read: if true; // Guests can browse rooms
      allow write: if isAdmin() || isReceptionist() || isHousekeeping() || isMaintenance();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.guestId || isAdmin() || isReceptionist() || isAccountant());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.guestId || isAdmin() || isReceptionist());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.guestId || isAdmin() || isKitchen() || isReceptionist());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || isKitchen() || isReceptionist());
    }

    match /maintenance/{ticketId} {
      allow read: if isAdmin() || isMaintenance() || isReceptionist() || isHousekeeping();
      allow write: if isAdmin() || isMaintenance() || isReceptionist() || isHousekeeping();
    }

    match /transactions/{txId} {
      allow read: if isAdmin() || isAccountant() || isReceptionist();
      allow write: if isAdmin() || isAccountant() || isReceptionist();
    }

    match /lost_and_found/{itemId} {
      allow read: if isAdmin() || isHousekeeping() || isReceptionist();
      allow write: if isAdmin() || isHousekeeping() || isReceptionist();
    }

    match /menu/{itemId} {
      allow read: if true; // Everyone can see the menu
      allow write: if isAdmin() || isKitchen();
    }
  }
}
